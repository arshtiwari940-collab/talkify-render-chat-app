# Server
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# Frontend URL(s) — comma-separated for multiple domains (required for Vercel + split deploy)
# Example: https://talkify.vercel.app,https://talkify-git-main-you.vercel.app
CLIENT_URL=http://localhost:5173

# Allow all *.vercel.app preview deployments (optional, useful during PR previews)
ALLOW_VERCEL_PREVIEWS=true

# Firebase / Firestore — use ONE of the two options below
# Option A: paste the full service account JSON as a single line
FIREBASE_SERVICE_ACCOUNT_JSON=
# Option B: path to the service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Cloudinary (for profile pics and chat media)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
